<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">

    <xs:element name="CustomBookRegistry">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="ebook" maxOccurs="unbounded" minOccurs="0">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="title" type="xs:string" minOccurs="0"/>
                            <xs:element name="createdBy" type="xs:string" minOccurs="0"/>
                            <xs:element name="totalCost" type="xs:double"/>
                            <xs:element name="chunks" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="chunkRef" maxOccurs="unbounded" minOccurs="0">
                                            <xs:complexType>
                                                <xs:sequence>
                                                    <xs:element name="note" type="xs:string" minOccurs="0"/>
                                                </xs:sequence>
                                                <xs:attribute name="bookId" type="xs:string"/>
                                                <xs:attribute name="chunkId" type="xs:string"/>
                                                <xs:attribute name="seq" type="xs:int" use="required"/>
                                            </xs:complexType>
                                        </xs:element>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                        <xs:attribute name="id" type="xs:string"/>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

</xs:schema>
